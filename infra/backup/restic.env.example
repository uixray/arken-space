RESTIC_REPOSITORY=s3:https://storage.yandexcloud.net/replace-with-private-bucket/arken-space
RESTIC_PASSWORD_FILE=/etc/arken-space/restic-password
AWS_ACCESS_KEY_ID=replace-with-static-key-id
AWS_SECRET_ACCESS_KEY=replace-with-static-secret-key
AWS_DEFAULT_REGION=ru-central1
APP_ROOT=/home/uixray/apps/arken-space
BACKUP_ROOT=/home/uixray/apps/arken-space-data/backups
MEDIA_ROOT=/home/uixray/apps/arken-space-data/media
PRODUCTION_COMPOSE_PROJECT=arken-space
BACKUP_HOST=arken-production
BACKUP_TAG=arken-space
RESTIC_CHECK=1
